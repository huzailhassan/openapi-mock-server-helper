generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {

  id Int @id @default(autoincrement())

  userId BigInt

  username String @unique

  environment String

  balance Float @default(0)

  createdAt DateTime @default(now())

  @@unique([userId, environment])

}